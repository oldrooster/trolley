# Trolley — development environment
# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Defaults to ./trolley.db relative to the backend directory if unset.
DATABASE_URL=sqlite:///./trolley.db

# ── Data directories ──────────────────────────────────────────────────────────
# Where uploaded receipt images and recipe images are stored.
# Defaults to /data/... which only exists in Docker; override for local dev.
UPLOADS_DIR=./data/receipts
IMAGES_DIR=./data/images

# ── AI provider ───────────────────────────────────────────────────────────────
# Options: vertex | gemini
# Can also be set via the Settings page in the app (stored in the DB).
AI_PROVIDER=gemini

# ── Google Vertex AI ──────────────────────────────────────────────────────────
# Required when AI_PROVIDER=vertex
VERTEX_PROJECT_ID=
VERTEX_LOCATION=global
# Path to a service account JSON key file with the "Vertex AI User" role.
# For local dev with the file at the repo root: ../vertex.json
# (uvicorn runs from backend/, so ../ steps up to the repo root)
GOOGLE_APPLICATION_CREDENTIALS=../vertex.json

# ── Google Gemini (AI Studio) ─────────────────────────────────────────────────
# Required when AI_PROVIDER=gemini
# Get a key at https://aistudio.google.com
GEMINI_API_KEY=
